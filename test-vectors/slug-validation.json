{
  "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
  "min_length": 3,
  "max_length": 50,
  "valid": [
    "my-space",
    "abc",
    "a-longer-space-name",
    "project42",
    "a1b2c3",
    "foo-bar-baz",
    "aaaaaaaaaabbbbbbbbbbccccccccccddddddddddeeeeeeeeee"
  ],
  "invalid": [
    { "input": "", "reason": "empty" },
    { "input": "ab", "reason": "too short" },
    { "input": "a", "reason": "too short" },
    { "input": "My-Space", "reason": "uppercase" },
    { "input": "my--space", "reason": "consecutive hyphens" },
    { "input": "-leading", "reason": "leading hyphen" },
    { "input": "trailing-", "reason": "trailing hyphen" },
    { "input": "has space", "reason": "contains space" },
    { "input": "has_underscore", "reason": "contains underscore" },
    { "input": "aaaaaaaaaabbbbbbbbbbccccccccccddddddddddeeeeeeeeeef", "reason": "too long (51 chars)" },
    { "input": "settings", "reason": "reserved" },
    { "input": "new", "reason": "reserved" },
    { "input": "admin", "reason": "reserved" },
    { "input": "api", "reason": "reserved" },
    { "input": "auth", "reason": "reserved" },
    { "input": "health", "reason": "reserved" },
    { "input": "metrics", "reason": "reserved" },
    { "input": "_", "reason": "reserved" }
  ]
}
